    <bpmn:scriptTask id="Activity_Consolidate_DU" name="Consolidate DU outputs" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:scriptVersion value="v3" />
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.ScriptTask" version="v1" />
          <uipath:context>
            <uipath:inputSchema><![CDATA[{"type":"object","properties":{"dd2579DocumentPath":{"type":"string"},"dd2579ContractDataJson":{"type":"string"},"sf1449ContractDataJson":{"type":"string"},"saadContractDataJson":{"type":"string"},"dftrContractDataJson":{"type":"string"}}}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"dd2579DocumentPath":"=vars.dd2579DocumentPath","dd2579ContractDataJson":"=vars.dd2579ContractDataJson","sf1449ContractDataJson":"=vars.sf1449ContractDataJson","saadContractDataJson":"=vars.saadContractDataJson","dftrContractDataJson":"=vars.dftrContractDataJson"}]]></uipath:input>
          <uipath:output name="contractDataJson" type="string" var="contractDataJson" source="=result.response" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>edge_dftr_consolidate</bpmn:incoming>
      <bpmn:outgoing>edge_consolidate_agent</bpmn:outgoing>
      <bpmn:script><![CDATA[
function normalizeDocument(documentType, parsedDocument, sourceEnvelope) {
  if (!parsedDocument || typeof parsedDocument !== "object" || Array.isArray(parsedDocument)) {
    return {
      documentType: documentType,
      processingState: "ParseError",
      errorDetails: "Document payload was not a JSON object.",
      extractedJson: parsedDocument
    };
  }

  if (!parsedDocument.documentType) {
    parsedDocument.documentType = documentType;
  }
  parsedDocument.sourceWorkflowDocumentType = sourceEnvelope && sourceEnvelope.documentType ? sourceEnvelope.documentType : documentType;
  parsedDocument.sourceWorkflowContractBatchId = sourceEnvelope && sourceEnvelope.contractBatchId ? sourceEnvelope.contractBatchId : parsedDocument.contractBatchId || "";
  return parsedDocument;
}

function parseDocuments(documentType, payload) {
  if (!payload || String(payload).trim() === "") {
    return [{ documentType: documentType, processingState: "Missing", extractedJson: null }];
  }

  try {
    var parsed = JSON.parse(payload);

    if (Array.isArray(parsed)) {
      return parsed.map(function (item) {
        return normalizeDocument(documentType, item, { documentType: documentType });
      });
    }

    if (parsed && Array.isArray(parsed.documents)) {
      if (parsed.documents.length === 0) {
        return [{
          documentType: documentType,
          processingState: "NoRecords",
          contractBatchId: parsed.contractBatchId || "",
          extractedJson: null
        }];
      }

      return parsed.documents.map(function (item) {
        return normalizeDocument(documentType, item, parsed);
      });
    }

    return [normalizeDocument(documentType, parsed, { documentType: documentType })];
  } catch (error) {
    return [{
      documentType: documentType,
      processingState: "ParseError",
      errorDetails: String(error),
      extractedJson: payload
    }];
  }
}

var documents = []
  .concat(parseDocuments("DD2579", dd2579ContractDataJson))
  .concat(parseDocuments("SF1449", sf1449ContractDataJson))
  .concat(parseDocuments("SAAD", saadContractDataJson))
  .concat(parseDocuments("DF_TR", dftrContractDataJson));

var batchId = "";
for (var i = 0; i < documents.length; i++) {
  if (documents[i] && documents[i].contractBatchId) {
    batchId = documents[i].contractBatchId;
    break;
  }
}

var consolidated = {
  contractBatchId: batchId,
  source: "Maestro",
  dataFabric: {
    entityName: "DLADataService",
    entityId: "73b82488-f560-f111-8fcb-002248a16d28",
    sourceOfTruth: true
  },
  threeWayMatch: {
    primaryDocumentType: "DD2579",
    dd2579DocumentPath: dd2579DocumentPath || "",
    comparisonDocumentTypes: ["SF1449", "SAAD", "DF_TR"]
  },
  documents: documents
};

return { response: JSON.stringify(consolidated) };
]]></bpmn:script>
    </bpmn:scriptTask>
